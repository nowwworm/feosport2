# Скопируй в deploy/.env и заполни:
# cp deploy/.env.example deploy/.env

# PostgreSQL
POSTGRES_DB=feosport2
POSTGRES_USER=feosport
POSTGRES_PASSWORD=ЗАМЕНИ_НА_СИЛЬНЫЙ_ПАРОЛЬ

# JWT — генерировать: openssl rand -hex 32
JWT_SECRET=ЗАМЕНИ_НА_СЛУЧАЙНУЮ_СТРОКУ_64_СИМВОЛА

# Порт Nginx на хосте (80 по умолчанию)
HTTP_PORT=80

# FormDesigner синхронизация (логин аккаунта formdesigner.ru)
FD_EMAIL=
FD_PASSWORD=
FD_FORM_ID=245167
