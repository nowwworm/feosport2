# ─────────────────────────────────────────────────────────────────────────────
#  FeoSport2 — переменные окружения
#  Скопируй этот файл в .env и заполни значения перед запуском.
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── База данных ───────────────────────────────────────────────────────────────
DB_NAME=feosport2
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Unified Docker stack refuses to start until DB_PASSWORD is set explicitly.

# ── JWT ───────────────────────────────────────────────────────────────────────
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_VERY_LONG_SECRET
# Unified Docker stack refuses to start until JWT_SECRET is set explicitly.

# ── FormDesigner CRM (опционально) ───────────────────────────────────────────
# Если не нужна синхронизация — оставь пустыми
FD_EMAIL=
FD_PASSWORD=
FD_FORM_ID=245167

# ── Frontend ──────────────────────────────────────────────────────────────────
# IP или hostname сервера в локальной сети (для доступа с телефонов)
# Пример: VITE_API_URL=http://192.168.1.100
VITE_API_URL=http://localhost

# ── Nginx ─────────────────────────────────────────────────────────────────────
# Порт на котором слушает nginx (по умолчанию 80)
HTTP_PORT=80

# ── CORS (только для production / qa) ─────────────────────────────────────────
# NODE_ENV=production или qa — список разрешённых origins через запятую.
# В development (NODE_ENV не задан) CORS открыт автоматически.
# Пример: ALLOWED_ORIGINS=http://192.168.1.100,https://feosport.railway.app
NODE_ENV=development
ALLOWED_ORIGINS=
