# ─────────────────────────────────────────────────────────────────────────────
#  FeoSport2 — переменные окружения для Railway QA
#  Скопируй значения в Railway → Project → Variables
#  НЕ коммить этот файл с реальными секретами!
# ─────────────────────────────────────────────────────────────────────────────

# ── Окружение ─────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── База данных (Railway Postgres plugin — берётся автоматически) ─────────────
# Railway сам проставит DATABASE_URL если добавить Postgres plugin.
# Если используешь свой кластер — задай вручную:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_NAME=feosport2
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_VERY_LONG_SECRET_64_CHARS

# ── FormDesigner CRM (если нужна синхронизация на QA) ────────────────────────
FD_EMAIL=
FD_PASSWORD=
FD_FORM_ID=245167

# ── CORS ──────────────────────────────────────────────────────────────────────
# Railway выдаст домен вида https://feosport2-production.up.railway.app
# Укажи его здесь:
ALLOWED_ORIGINS=https://YOUR-APP.up.railway.app

# ── Frontend ──────────────────────────────────────────────────────────────────
# Должен совпадать с Railway-доменом (без слеша на конце)
VITE_API_URL=https://YOUR-APP.up.railway.app

# ── Port (Railway задаёт автоматически через $PORT) ───────────────────────────
# Не нужно задавать вручную — Railway инжектит PORT сам.
# PORT=8090
