# ── Зависимости ───────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Сборки ────────────────────────────────────────────────────────────────────
dist/
frontend/dist/

# ── Секреты (НИКОГДА не коммитить) ───────────────────────────────────────────
.env
.env.local
.env.production
deploy/.env

# ── Staging / временные файлы сборщика ───────────────────────────────────────
deploy/windows/build/staging/
deploy/windows/build/deps/
deploy/windows/output/

# ── Логи ──────────────────────────────────────────────────────────────────────
*.log
install.log

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Тяжёлые бинарники / артефакты (не нужны в репо) ──────────────────────────
*.zip
*.exe
*.pdf

# ── IDE ────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.suo
*.user

# ── feoTEST — сторонний код ───────────────────────────────────────────────────
# Исходники TMX нужны для CI-сборки; исключаем только артефакты
feoTEST/**/node_modules/
feoTEST/**/.git/
feoTEST/**/dist/
