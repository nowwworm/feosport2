# ── Зависимости ───────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
.tools/
.npm-cache/
.pnpm-store/
.runtime-logs/

# ── Сборки ────────────────────────────────────────────────────────────────────
dist/
frontend/dist/

# ── Секреты (НИКОГДА не коммитить) ───────────────────────────────────────────
.env
.env.local
.env.production
deploy/.env

# ── Staging / временные файлы сборщика ───────────────────────────────────────
deploy/windows/build/staging/
deploy/windows/build/deps/
deploy/windows/output/

# ── Логи ──────────────────────────────────────────────────────────────────────
*.log
install.log

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Тяжёлые бинарники / артефакты (не нужны в репо) ──────────────────────────
*.zip
*.exe
*.pdf
*.docx
*.doc
*.xlsx
*.xls

# ── Word / Office lock-файлы (создаются при открытом документе) ──────────────
~$*

# ── IDE / AI tooling (локальные конфиги) ─────────────────────────────────────
.idea/
.vscode/
.gemini/
*.suo
*.user

# ── Артефакты Playwright (регенерируются) ────────────────────────────────────
frontend/test-results/
frontend/playwright-report/

# ── feoTEST — сторонний код ───────────────────────────────────────────────────
# Только TMX нужен для CI-сборки; остальные папки игнорируем полностью
feoTEST/courthive-components/
feoTEST/factory/
feoTEST/pdf-factory/
feoTEST/provider-config/
feoTEST/scoringVisualizations/
# В TMX исключаем только артефакты сборки и зависимости
feoTEST/**/node_modules/
feoTEST/**/.git/
feoTEST/**/dist/
feoTEST/**/playwright-report/

.claude/skills/run-feosport2/.server.pid

# ── Загруженные документы (локальное хранение) ─────────────────────────────
data/
backend/data/
uploads/
